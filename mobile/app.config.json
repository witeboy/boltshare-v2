{
  "app": {
    "name": "BoltShare",
    "versionName": "1.0.0",
    "versionCode": 1
  },
  "identity": {
    "androidPackage": "app.rcinc.boltshare",
    "iosBundleId": "app.rcinc.boltshare",
    "urlScheme": "boltshare"
  },
  "web": {
    "url": "https://boltshare.rcinc.app/",
    "allowedHosts": [
      "boltshare.rcinc.app"
    ],
    "associatedPaths": [
      "/receive/*",
      "/receive-code",
      "/dashboard",
      "/history",
      "/upload",
      "/team",
      "/settings"
    ]
  },
  "features": {
    "fileUpload": true,
    "downloadManager": true,
    "nativeShare": true,
    "deepLinks": true,
    "ads": false,
    "pushNotifications": false,
    "camera": false,
    "microphone": false,
    "location": false
  },
  "android": {
    "minSdk": 24,
    "compileSdk": 36,
    "targetSdk": 36,
    "javaVersion": 21
  },
  "ios": {
    "deploymentTarget": "15.0"
  }
}
