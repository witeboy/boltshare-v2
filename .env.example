NEXT_PUBLIC_APP_URL=https://boltshare.rcinc.app
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Cloudflare R2 (server-only S3 credentials scoped to boltshare-transfers)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=boltshare-transfers
# Optional lower ceiling. The default is R2's maximum object size (~4.995 TiB).
MAX_TRANSFER_BYTES=

# Existing application integrations
# Bunny values are retained only for downloads/deletion of pre-migration files.
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_HOST=storage.bunnycdn.com
BUNNY_STORAGE_PASSWORD=
BUNNY_CDN_HOSTNAME=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
CRON_SECRET=

# Native app association (public certificate/team identifiers, not secrets)
# Comma-separated SHA-256 fingerprints from Play App Signing / release certificates.
ANDROID_APP_SHA256_FINGERPRINTS=
# Apple Developer Team ID used for the iOS Universal Link association.
APPLE_TEAM_ID=
